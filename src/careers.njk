---
title: "Work With Us | Mountain Oasis Bar & Grill"
description: "Join the Mountain Oasis Bar & Grill team in Buena Vista, CO. Apply online today."
---

{% extends "layouts/base.njk" %}

{% block content %}
  <section class="bg-cream min-h-screen py-16 relative overflow-hidden"
    style="background-image: url('{{ "/assets/images/squiggle-1.png" | url }}'); background-size: cover; background-position: center; background-blend-mode: multiply;">

    <div class="relative max-w-screen-md mx-auto px-4 z-10">

      <!-- Form card -->
      <div class="retro-card">
        <div class="text-center mb-4">
          <span class="retro-badge">{{ client.name }}</span>
          <h1 class="font-display text-5xl md:text-6xl text-pine mt-4 leading-none">Join Our Team</h1>
        </div>
        <svg viewBox="0 0 300 12" preserveAspectRatio="none" class="w-full h-3 mb-5 text-navy"><path d="M0,6 C25,0 50,12 75,6 C100,0 125,12 150,6 C175,0 200,12 225,6 C250,0 275,12 300,6" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
        <p class="text-bark/70 mb-6">We're always looking for passionate, hardworking people to be part of the Mountain Oasis family. Whether you're an experienced hospitality pro or just getting started, we'd love to hear from you. Fill out the form below and we'll be in touch.</p>
        <iframe src="https://88restaurants.com/{{ client.eightyEightPath }}/employment_submissions/new" frameborder="0" width="100%" height="650" scrolling="no"></iframe>
      </div>

    </div>
  </section>
{% endblock %}
