<!DOCTYPE html>
<html lang="en">
  <head>
    <!-- Standard meta tags -->
    <meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{{ description or 'Mountain Oasis Bar & Grill — bold comfort food, strong drinks, and a laid-back mountain vibe in Buena Vista, CO.' }}">
<link rel="canonical" href="{{ client.domain }}{{ page.url }}">

    <!-- Social Media Display -->
    <meta property="og:title" content="{{ title }}"/>
    <meta property="og:description" content="{{ description }}"/>
    <meta property="og:type" content="website"/>
    <meta property="og:url" content="{{ client.domain }}{{ page.url }}"/>
    <meta property="og:image" content="{{ client.domain }}/assets/images/og-image.webp"/>
    <meta property="og:image:secure_url" content="{{ client.domain }}/assets/images/og-image.webp"/>

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image"/>
    <meta name="twitter:image" content="{{ client.domain }}/assets/images/og-image.webp"/>

    <!-- Favicons -->
    <link rel="apple-touch-icon" sizes="180x180" href="{{ "/assets/favicons/apple-touch-icon.png" | url }}">
    <link rel="icon" type="image/png" sizes="32x32" href="{{ "/assets/favicons/favicon-32x32.png?v1" | url }}">
    <link rel="icon" type="image/png" sizes="16x16" href="{{ "/assets/favicons/favicon-16x16.png" | url }}">
    <link rel="manifest" href="{{ "/assets/favicons/site.webmanifest" | url }}">
    <meta name="msapplication-TileColor" content="#da532c">
    <meta name="theme-color" content="#ffffff">

    <!-- Sitewide Stylesheets and Scripts -->
    <link rel="stylesheet" href="{{ "/assets/css/styles.css" | url }}">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Shrikhand&family=Roboto:wght@400;700&display=swap">

    {% block head %}{% endblock %}

    <title>{{ title }}</title>

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Restaurant",
        "name": "Mountain Oasis Bar & Grill",
        "url": "{{ client.domain }}/",
        "logo": "{{ client.domain }}/assets/images/logo.png",
        "image": "{{ client.domain }}/assets/images/og-image.webp",
        "telephone": "+1-{{ client.phone }}",
        "email": "{{ client.email }}",
        "servesCuisine": ["American", "Bar & Grill"],
        "priceRange": "$$",
        "menu": "{{ client.domain }}/menu/",
        "acceptsReservations": "True",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "{{ client.address.street }}",
          "addressLocality": "{{ client.address.city }}",
          "addressRegion": "{{ client.address.state }}",
          "postalCode": "{{ client.address.zip }}",
          "addressCountry": "US"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 38.8431025,
          "longitude": -106.1329855
        },
        "openingHoursSpecification": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday"],
            "opens": "11:00",
            "closes": "21:00"
          },
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Friday", "Saturday"],
            "opens": "11:00",
            "closes": "00:00"
          },
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": "Sunday",
            "opens": "12:00",
            "closes": "19:00"
          }
        ],
        "sameAs": ["{{ client.socialMedia.facebook }}"]
      }
    </script>

    <!-- Google tag Mountain Oasis (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-576BSMLNP6"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-576BSMLNP6');
    </script>

  </head>

  <body{% if bodyClass %} class="{{ bodyClass }}"{% endif %}{% if bodyStyle %} style="{{ bodyStyle }}"{% endif %}>
    {% include "components/header.njk" %}
    <main>
      {% block content %}{% endblock %}
    </main>
    {% if not hideFooter %}{% include "components/footer.njk" %}{% endif %}
    <script src="{{ "/assets/js/main.js" | url }}"></script>
    {% block scripts %}{% endblock %}
  </body>
</html>