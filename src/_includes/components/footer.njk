<footer class="bg-bark text-cream">
  <div class="max-w-screen-xl mx-auto px-4 py-12">

    <div class="grid md:grid-cols-3 gap-10 mb-10">

      <!-- Brand -->
      <div>
        <p class="font-display text-3xl text-cream leading-none mb-2">{{ client.name }}</p>
        <p class="text-cream/60 text-sm">Bar &amp; Grill · Buena Vista, CO</p>
        <p class="text-cream/60 text-sm mt-1">{{ client.address.street }}</p>
        <p class="text-cream/60 text-sm">{{ client.address.city }}, {{ client.address.state }} {{ client.address.zip }}</p>
        <a href="tel:{{ client.phone }}" class="text-gold text-sm font-bold mt-2 block hover:underline">{{ client.phone }}</a>
        <a href="mailto:{{ client.email }}" class="text-gold text-sm font-bold hover:underline">{{ client.email }}</a>
      </div>

      <!-- Nav links -->
      <div>
        <p class="text-cream/40 text-xs tracking-widest uppercase font-bold mb-4">Explore</p>
        <ul class="space-y-3">
          <li><a href="{{ "/menu.html" | url }}"       class="text-cream/80 text-sm hover:text-gold transition-colors">Menu</a></li>
          <li><a href="{{ "/gift-cards.html" | url }}" class="text-cream/80 text-sm hover:text-gold transition-colors">Gift Cards</a></li>
          <li><a href="{{ "/" | url }}#contact"    class="text-cream/80 text-sm hover:text-gold transition-colors">Contact</a></li>
          <li><a href="{{ "/careers.html" | url }}"    class="text-cream/80 text-sm hover:text-gold transition-colors">Jobs</a></li>
        </ul>
      </div>

      <!-- Social + Order -->
      <div>
        <p class="text-cream/40 text-xs tracking-widest uppercase font-bold mb-4">Connect</p>
        <ul class="space-y-3 mb-6">
          <li>
            <a href="{{ client.socialMedia.facebook }}" target="_blank" rel="noopener noreferrer"
               class="text-cream/80 text-sm hover:text-gold transition-colors">Facebook</a>
          </li>
          <li>
            <a href="{{ client.address.googlePlacesUrl }}" target="_blank" rel="noopener noreferrer"
               class="text-cream/80 text-sm hover:text-gold transition-colors">Google Maps</a>
          </li>
        </ul>
        <a href="https://88restaurants.com/{{ client.eightyEightPath }}/online_orders/new"
           target="_blank" rel="noopener noreferrer"
           class="retro-btn-gold text-xs">
          Order Online
        </a>
      </div>

    </div>

    <div class="border-t border-cream/10 pt-6 flex flex-col md:flex-row items-center justify-between gap-3 text-sm text-cream/40">
      <span>&copy; {{ global.currentYear }} {{ client.name }}. All Rights Reserved.</span>
      <span>Website by <a href="https://88restaurants.com/features/restaurant_website_design_and_hosting" target="_blank" rel="noopener noreferrer" class="hover:text-gold transition-colors">88 Restaurants</a></span>
    </div>

  </div>
</footer>
