<header class="sticky top-7 z-50 relative">

  <!-- Pill bar -->
  <div class="bg-pine border-4 border-bark rounded-full mx-4">
    <div class="max-w-screen-xl mx-auto px-8 py-3">

      <!-- Desktop: 3-column grid -->
      <div class="hidden md:grid grid-cols-3 items-center gap-4">

        <!-- Left nav -->
        <nav class="flex items-center gap-6">
          <a href="{{ "/menu.html" | url }}"       class="text-cream font-bold text-sm tracking-widest uppercase hover:text-gold transition-colors">Menu</a>
          {# <a href="{{ "/gift-cards.html" | url }}" class="text-cream font-bold text-sm tracking-widest uppercase hover:text-gold transition-colors">Gift Cards</a> #}
          <a href="{{ "/" | url }}#contact"    class="text-cream font-bold text-sm tracking-widest uppercase hover:text-gold transition-colors">Contact</a>
          <a href="{{ "/gallery.html" | url }}"    class="text-cream font-bold text-sm tracking-widest uppercase hover:text-gold transition-colors">Gallery</a>
          <a href="{{ "/events.html" | url }}"     class="text-cream font-bold text-sm tracking-widest uppercase hover:text-gold transition-colors">Events</a>
          <a href="{{ "/careers.html" | url }}"    class="text-cream font-bold text-sm tracking-widest uppercase hover:text-gold transition-colors">Jobs</a>
        </nav>

        <!-- Empty center — logo is absolutely positioned -->
        <div></div>

        <!-- Right CTA -->
        <div class="flex justify-end">
          <a href="https://88restaurants.com/{{ client.eightyEightPath }}/online_orders/new"
             target="_blank" rel="noopener noreferrer"
             class="retro-btn-gold text-sm">
            Order Online
          </a>
        </div>

      </div>

      <!-- Mobile: hamburger only (logo is absolutely positioned like desktop) -->
      <div class="flex md:hidden items-center justify-end">
        <button id="mobile-menu-btn" class="text-cream p-1 relative z-30" aria-label="Open menu">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>

    </div>
  </div>

  <!-- Desktop logo — vertically centered on the pill, overflows on load -->
  <a href="{{ "/" | url }}" class="hidden md:block absolute left-1/2 -translate-x-1/2 top-1/2 -translate-y-1/2 z-20">
    <img id="header-logo" src="{{ "/assets/images/logo.png" | url }}" alt="{{ client.name }}" class="header-logo w-auto">
  </a>

  <!-- Mobile logo — same overflow behaviour, hidden on md+ -->
  <a href="{{ "/" | url }}" class="md:hidden absolute left-8 top-1/2 -translate-y-1/2 z-20">
    <img id="mobile-header-logo" src="{{ "/assets/images/logo.png" | url }}" alt="{{ client.name }}" class="mobile-header-logo w-auto">
  </a>

  <!-- Mobile dropdown — floats below the pill -->
  <div id="mobile-menu" class="hidden absolute top-full left-4 right-4 mt-2 bg-pine border-4 border-bark rounded-2xl z-50">
    <nav class="px-6 py-5 flex flex-col gap-5">
      <a href="{{ "/menu.html" | url }}"       class="text-cream font-bold text-sm tracking-widest uppercase hover:text-gold transition-colors">Menu</a>
      <a href="{{ "/" | url }}#contact"    class="text-cream font-bold text-sm tracking-widest uppercase hover:text-gold transition-colors">Contact</a>
      <a href="{{ "/gallery.html" | url }}"    class="text-cream font-bold text-sm tracking-widest uppercase hover:text-gold transition-colors">Gallery</a>
      <a href="{{ "/events.html" | url }}"     class="text-cream font-bold text-sm tracking-widest uppercase hover:text-gold transition-colors">Events</a>
      <a href="{{ "/careers.html" | url }}"    class="text-cream font-bold text-sm tracking-widest uppercase hover:text-gold transition-colors">Jobs</a>
      <a href="https://88restaurants.com/{{ client.eightyEightPath }}/online_orders/new"
         target="_blank" rel="noopener noreferrer"
         class="retro-btn-gold self-start">
        Order Online
      </a>
    </nav>
  </div>

</header>
